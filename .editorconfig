# ============================================================
# EditorConfig - 知讯项目编码规范
# 确保所有开发者使用统一的编辑器设置，防止编码问题
# 更多配置：https://editorconfig.org/
# ============================================================

# 根目录标记
root = true

# 默认配置 - 所有文件
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java 文件
[*.java]
indent_size = 4
max_line_length = 120

# XML / POM 文件
[*.xml]
indent_size = 4

# SQL 文件
[*.sql]
indent_size = 4

# YAML 文件
[*.{yml,yaml}]
indent_size = 2

# Python 文件
[*.py]
indent_size = 4

# Shell 脚本
[*.{sh,bash}]
indent_size = 4

# Markdown 文件
[*.md]
trim_trailing_whitespace = false

# 批处理文件（PowerShell）
[*.{bat,ps1}]
indent_size = 4
end_of_line = crlf

# Windows 特定文件
[*.{cmd,bat}]
end_of_line = crlf