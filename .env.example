# ==================== 智讯系统环境变量配置 ====================
# 复制此文件为 .env 并修改为实际值
# cp .env.example .env
#
# ⚠️  安全警告：以下默认密码仅用于本地开发，生产环境必须修改！
# ⚠️  请务必为所有密码类变量设置强密码，避免使用默认值。

# ==================== MySQL 配置 ====================
# ⚠️  生产环境必须修改 MYSQL_ROOT_PASSWORD，请使用强密码
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=zhixun
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
# ⚠️  生产环境建议启用 REDIS_PASSWORD 并设置强密码
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== RabbitMQ 配置 ====================
# ⚠️  生产环境必须修改 RABBITMQ_USER 和 RABBITMQ_PASSWORD，请勿使用 guest/guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== MinIO 配置 ====================
# ⚠️  生产环境必须修改 MINIO_ACCESS_KEY 和 MINIO_SECRET_KEY，请勿使用 minioadmin/minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=zhixun321
MINIO_SECRET_KEY=zhixun321
MINIO_BUCKET=zhixun

# ==================== OpenSearch 配置 ====================
# ⚠️  生产环境必须修改 OPENSEARCH_PASSWORD，请使用符合复杂度要求的强密码
OPENSEARCH_PASSWORD=Zhixun321!
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_TRANSPORT_PORT=9600

# ==================== Spring Boot 后端配置 ====================
SERVER_PORT=8080

# ⚠️  生产环境必须修改 JWT 密钥，请使用随机生成的长字符串（至少256位）
JWT_ACCESS_SECRET=zhixun-access-secret-key-2024-must-be-at-least-256-bits-long
JWT_REFRESH_SECRET=zhixun-refresh-secret-key-2024-must-be-at-least-256-bits-long

# JWT 令牌过期时间（秒）
JWT_ACCESS_EXPIRATION=7200
JWT_REFRESH_EXPIRATION=604800

# ⚠️  生产环境必须修改 AES 密钥，请使用随机生成的32字符字符串
AES_SECRET_KEY=zhixun-aes-secret-32bytes-key!!

# ==================== 前端配置 ====================
CLIENT_PORT=3000
ADMIN_PORT=3001

# ==================== Nginx 配置 ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
