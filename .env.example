# ==================== 知讯系统环境变量配置 ====================
# 复制此文件为 .env 并修改为实际值
# cp .env.example .env
#
# ⚠️  安全警告：以下默认密码仅用于本地开发，生产环境必须修改！
# ⚠️  请务必为所有密码类变量设置强密码，避免使用默认值。
# ⚠️  生产部署请使用 .env.production.example 模板。

# ==================== MySQL 配置 ====================
# ⚠️  生产环境必须修改 MYSQL_ROOT_PASSWORD，请使用强密码（至少16位，含大小写字母、数字和特殊字符）
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=zhixun
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
# ⚠️  生产环境建议启用 REDIS_PASSWORD 并设置强密码
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== RabbitMQ 配置 ====================
# ⚠️  生产环境必须修改 RABBITMQ_USER 和 RABBITMQ_PASSWORD，请勿使用 guest/guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== MinIO 配置 ====================
# ⚠️  生产环境必须修改 MINIO_ACCESS_KEY 和 MINIO_SECRET_KEY，请勿使用弱密码
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=zhixun321
MINIO_SECRET_KEY=zhixun321
MINIO_BUCKET=zhixun

# ==================== OpenSearch 配置 ====================
# ⚠️  生产环境必须修改 OPENSEARCH_PASSWORD，请使用符合复杂度要求的强密码
OPENSEARCH_PASSWORD=Zhixun321!
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_TRANSPORT_PORT=9600

# ==================== 邮件配置 ====================
# QQ邮箱SMTP服务器（使用SSL 465端口）
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
# QQ邮箱地址（即发件人邮箱）
MAIL_USERNAME=your_qq@qq.com
# QQ邮箱授权码（非QQ密码，需在QQ邮箱设置-账户中开启SMTP服务并获取授权码）
# ⚠️ 安全警告：请勿将真实授权码提交到版本控制系统
MAIL_PASSWORD=your_qq_auth_code_example

# ==================== Spring Boot 后端配置 ====================
SERVER_PORT=8080

# ==================== JWT 密钥 ====================
# ⚠️  生产环境必须使用随机生成的强密钥，禁止使用默认值
# 生成命令：openssl rand -base64 32
# 示例格式（请勿直接使用）：
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# JWT 令牌过期时间（秒）
JWT_ACCESS_EXPIRATION=7200
JWT_REFRESH_EXPIRATION=604800

# ==================== AES 加密密钥 ====================
# ⚠️  生产环境必须使用随机生成的32字节密钥，禁止使用默认值
# 生成命令：openssl rand -base64 32
AES_SECRET_KEY=

# ==================== SSR 通信密钥 ====================
# ⚠️  生产环境必须设置，用于 Nuxt SSR 与后端的安全通信
# 生成命令：openssl rand -base64 32
SSR_SECRET=

# ==================== 管理员账号 ====================
# 首次部署时会自动创建管理员账号，通过以下环境变量设置凭据
# ⚠️  生产环境必须修改默认值
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ==================== 前端配置 ====================
CLIENT_PORT=3000
ADMIN_PORT=3001

# ==================== Nginx 配置 ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== 智谱AI 配置 ====================
# 免费模型 glm-4.7-flash，注册即用：https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.7-flash

# ==================== CORS 配置 ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
