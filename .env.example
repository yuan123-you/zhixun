# ==================== 知讯系统环境变量配置 ====================
# 复制此文件为 .env 并修改为实际值
# cp .env.example .env
#
# ⚠️  安全警告：以下默认密码仅用于本地开发，生产环境必须修改！
# ⚠️  请务必为所有密码类变量设置强密码，避免使用默认值。
# ⚠️  生产部署请使用 .env.production.example 模板。

# ==================== MySQL 配置 ====================
# ⚠️  生产环境必须修改 MYSQL_ROOT_PASSWORD，请使用强密码（至少16位，含大小写字母、数字和特殊字符）
# 本地开发：MYSQL_HOST=localhost
# Docker 部署：MYSQL_HOST=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=zhixun
# 从库（单节点部署时与主库相同；读写分离部署时改为从库地址）
MYSQL_SLAVE_HOST=localhost
MYSQL_SLAVE_PORT=3306
MYSQL_SLAVE_USER=root
MYSQL_SLAVE_PASSWORD=123456
MYSQL_SLAVE_DB=zhixun

# ==================== Redis 配置 ====================
# ⚠️  生产环境建议启用 REDIS_PASSWORD 并设置强密码
# 本地开发：REDIS_HOST=localhost
# Docker 部署：REDIS_HOST=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== RabbitMQ 配置 ====================
# ⚠️  生产环境必须修改 RABBITMQ_USER 和 RABBITMQ_PASSWORD，请勿使用 guest/guest
# 本地开发：RABBITMQ_HOST=localhost
# Docker 部署：RABBITMQ_HOST=rabbitmq
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== MinIO 配置 ====================
# ⚠️  生产环境必须修改 MINIO_ACCESS_KEY 和 MINIO_SECRET_KEY，请勿使用弱密码
# 本地开发：MINIO_ENDPOINT=http://localhost:9000
# Docker 部署：MINIO_ENDPOINT=http://minio:9000
MINIO_ENDPOINT=http://localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=zhixun321
MINIO_SECRET_KEY=zhixun321
MINIO_BUCKET=zhixun

# ==================== OpenSearch 配置 ====================
# ⚠️  生产环境必须修改 OPENSEARCH_PASSWORD，请使用符合复杂度要求的强密码
# 本地开发：OPENSEARCH_HOSTS=http://localhost:9201
# Docker 部署：OPENSEARCH_HOSTS=http://opensearch:9201
# 端口规划（与 docs/PORTS.md 一致）：HTTP REST 统一使用 9201，让出 8080 给 Spring Boot
# 历史原因：OpenSearch 2.11 的 performance analyzer 默认监听 8080，会与 Spring Boot 冲突。
OPENSEARCH_HOSTS=http://localhost:9201
OPENSEARCH_PASSWORD=Zhixun321!
OPENSEARCH_HTTP_PORT=9201
OPENSEARCH_TRANSPORT_PORT=9600

# ==================== Sentinel 配置 ====================
# 本地开发：SENTINEL_DASHBOARD=localhost:8080
# Docker 部署：SENTINEL_DASHBOARD=server:8080
SENTINEL_DASHBOARD=localhost:8080
SENTINEL_TRANSPORT_PORT=8719

# ==================== 邮件配置 ====================
# QQ邮箱SMTP服务器（使用SSL 465端口）
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
# QQ邮箱地址（即发件人邮箱）
MAIL_USERNAME=your_qq@qq.com
# QQ邮箱授权码（非QQ密码，需在QQ邮箱设置-账户中开启SMTP服务并获取授权码）
# ⚠️ 安全警告：请勿将真实授权码提交到版本控制系统
MAIL_PASSWORD=your_qq_auth_code_example

# ==================== Spring Boot 后端配置 ====================
SERVER_PORT=8080

# ==================== JWT 密钥 ====================
# ⚠️  生产环境必须使用随机生成的强密钥，禁止使用默认值
# 生成命令：openssl rand -base64 32
# 示例格式（请勿直接使用）：
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# JWT 令牌过期时间（秒）
JWT_ACCESS_EXPIRATION=604800
JWT_REFRESH_EXPIRATION=604800

# ==================== AES 加密密钥 ====================
# ⚠️  生产环境必须使用随机生成的32字节密钥，禁止使用默认值
# 生成命令：openssl rand -base64 32
AES_SECRET_KEY=

# ==================== 管理员账号 ====================
# 首次部署时会自动创建管理员账号，通过以下环境变量设置凭据
# ⚠️  生产环境必须修改默认值
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ==================== 前端配置 ====================
# ⚠️  端口定义与 docs/PORTS.md 保持一致，是端口号的唯一事实来源
CLIENT_PORT=3500
ADMIN_PORT=3001

# ==================== Nginx 配置 ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== 智谱AI 配置 ====================
# 免费模型 glm-4.7-flash（300亿参数MoE），注册即用：https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.7-flash

# ==================== 腾讯地图 配置 ====================
# 用于 IP 定位（/ws/location/v1/ip）和逆地理编码（/ws/geocoder/v1/）
# 申请地址：https://lbs.qq.com/webservice_v1/guide-ip
# 为空时 IP 定位自动降级到 ip-api 公共接口
TENCENT_MAP_KEY=
# 是否启用腾讯地图 IP 定位（生产建议 true）
TENCENT_MAP_ENABLED=true

# ==================== CORS 配置 ====================
# 允许的前端来源（与前端端口 CLIENT_PORT/ADMIN_PORT 保持一致）
# 3500 = client 正式端口；5173 = Vite dev 默认端口；3001 = admin 端口
CORS_ALLOWED_ORIGINS=http://localhost:3500,http://localhost:5173,http://localhost:3001
