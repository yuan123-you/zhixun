# ==================== 智讯系统环境变量配置 ====================
# 复制此文件为 .env 并修改为实际值
# cp .env.example .env

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=zhixun123456
MYSQL_DATABASE=zhixun
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== RabbitMQ 配置 ====================
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== MinIO 配置 ====================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zhixun

# ==================== Spring Boot 后端配置 ====================
SERVER_PORT=8080

# JWT 密钥（生产环境请务必更换为随机长字符串）
JWT_ACCESS_SECRET=zhixun-access-secret-key-2024-must-be-at-least-256-bits-long
JWT_REFRESH_SECRET=zhixun-refresh-secret-key-2024-must-be-at-least-256-bits-long

# JWT 令牌过期时间（秒）
JWT_ACCESS_EXPIRATION=7200
JWT_REFRESH_EXPIRATION=604800

# AES 加密密钥（必须为32个字符）
AES_SECRET_KEY=zhixun-aes-secret-32bytes-key!!

# ==================== 前端配置 ====================
CLIENT_PORT=3000
ADMIN_PORT=3001

# ==================== Nginx 配置 ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
