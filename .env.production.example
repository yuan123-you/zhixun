# ==================== 知讯系统 生产环境变量配置 ====================
# 使用方式：
#   1. cp .env.production.example .env.production
#   2. 修改 .env.production 中所有标记为 CHANGE_ME 的值为实际凭据
#   3. docker compose --env-file .env.production up -d
#
# ⚠️  安全警告：
#   - .env.production 文件包含真实凭据，切勿提交到版本控制系统
#   - 已在 .gitignore 中排除 .env.production
#   - 所有密钥请使用 openssl rand -base64 32 生成
#   - 所有密码请使用密码管理器生成强随机密码（至少16位）

# ==================== MySQL 配置 ====================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=zhixun
MYSQL_SLAVE_HOST=mysql
MYSQL_SLAVE_PORT=3306
MYSQL_SLAVE_USER=root
MYSQL_SLAVE_PASSWORD=CHANGE_ME
MYSQL_SLAVE_DB=zhixun

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DATABASE=0

# ==================== RabbitMQ 配置 ====================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=zhixun
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_VHOST=/

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=zhixun

# ==================== OpenSearch 配置 ====================
OPENSEARCH_HOSTS=http://opensearch:9201
OPENSEARCH_PASSWORD=CHANGE_ME
OPENSEARCH_HTTP_PORT=9201
OPENSEARCH_TRANSPORT_PORT=9600

# ==================== Sentinel ====================
SENTINEL_DASHBOARD=server:8080
SENTINEL_TRANSPORT_PORT=8719

# ==================== 邮件配置 ====================
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME

# ==================== Spring Boot 后端 ====================
SERVER_PORT=8080

# ==================== JWT 密钥 (openssl rand -base64 32) ====================
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRATION=604800
JWT_REFRESH_EXPIRATION=604800

# ==================== AES 加密密钥 (openssl rand -base64 32) ====================
AES_SECRET_KEY=CHANGE_ME

# ==================== 管理员账号 ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ==================== 前端端口（与 docs/PORTS.md 一致） ====================
CLIENT_PORT=3500
ADMIN_PORT=3001

# ==================== Nginx ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== CORS 来源（生产域名） ====================
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ==================== 应用配置 ====================
APP_DATA_VERSION=20250625
OFFICIAL_ACCOUNT_ID=1

# ==================== 智谱AI 配置 ====================
# 免费模型 glm-4.7-flash（300亿参数MoE），注册即用：https://open.bigmodel.cn/
ZHIPU_API_KEY=CHANGE_ME
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.7-flash

# ==================== 腾讯地图配置 ====================
# 用于 IP 定位和逆地理编码，申请地址：https://lbs.qq.com/webservice_v1/guide-ip
TENCENT_MAP_KEY=CHANGE_ME
TENCENT_MAP_ENABLED=true

# ==================== OAuth 第三方登录（可选） ====================
WECHAT_APP_ID=
WECHAT_APP_SECRET=
QQ_APP_ID=
QQ_APP_KEY=

# ==================== Sentinel 限流熔断 ====================
SENTINEL_ENABLED=true
SENTINEL_TRANSPORT_PORT=8719
SENTINEL_DASHBOARD=server:8080

# ==================== 时区 ====================
TZ=Asia/Shanghai
