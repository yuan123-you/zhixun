  "testScenarios": [
    {
      "id": "TC-COMP-001",
      "name": "页面布局适配",
      "description": "验证页面在各断点下布局正确，无溢出或截断",
      "priority": "high"
    },
    {
      "id": "TC-COMP-002",
      "name": "触摸交互",
      "description": "验证移动端触摸操作正常（滑动、点击、长按）",
      "priority": "high"
    },
    {
      "id": "TC-COMP-003",
      "name": "字体渲染",
      "description": "验证各设备字体渲染清晰，无锯齿或模糊",
      "priority": "medium"
    },
    {
      "id": "TC-COMP-004",
      "name": "图片加载",
      "description": "验证图片在各设备分辨率下正确加载，支持WebP/AVIF降级",
      "priority": "high"
    },
    {
      "id": "TC-COMP-005",
      "name": "CSS兼容性",
      "description": "验证CSS特性在各浏览器中正确渲染（Flexbox、Grid、CSS变量等）",
      "priority": "high"
    },
    {
      "id": "TC-COMP-006",
      "name": "JavaScript兼容性",
      "description": "验证JS功能在各浏览器中正常运行（ES6+特性、API兼容性）",
      "priority": "high"
    },
    {
      "id": "TC-COMP-007",
      "name": "滚动性能",
      "description": "验证页面滚动流畅，无卡顿（目标60fps）",
      "priority": "medium"
    },
    {
      "id": "TC-COMP-008",
      "name": "横竖屏切换",
      "description": "验证移动端横竖屏切换后页面布局正确",
      "priority": "medium"
    },
    {
      "id": "TC-COMP-009",
      "name": "暗黑模式",
      "description": "验证系统暗黑模式下页面样式正确",
      "priority": "low"
    },
    {
      "id": "TC-COMP-010",
      "name": "网络降级",
      "description": "验证弱网环境下页面加载和功能可用性（3G/4G/离线）",
      "priority": "medium"
    }
  ]
}
